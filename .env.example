VISION_PROVIDER=openai-compatible

# MCP transport
MCP_TRANSPORT=stdio

# HTTP transport for private server deployment
# MCP_TRANSPORT=http
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=3000
# MCP_HTTP_PATH=/mcp
# MCP_AUTH_TOKEN=replace_with_a_long_random_token
# MCP_AUTH_HEADER=authorization
# MCP_AUTH_SCHEME=Bearer

# OpenAI-compatible endpoint. Use the /v1 base URL; the server appends /chat/completions.
VISION_BASE_URL=https://api.openai.com/v1
VISION_API_KEY=your_api_key
VISION_MODEL=gpt-4o-mini

# Optional custom headers, JSON string
VISION_HEADERS={}

# Default behavior
VISION_TEMPERATURE=0.1
VISION_MAX_TOKENS=4096
VISION_TIMEOUT_MS=60000

# Image limits
VISION_MAX_IMAGE_MB=10

# Cache
VISION_CACHE_ENABLED=true
VISION_CACHE_DIR=.vision-cache

# SiliconFlow Qwen example:
# VISION_BASE_URL=https://api.siliconflow.cn/v1
# VISION_MODEL=Qwen/Qwen3-VL-8B-Thinking
