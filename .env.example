OCULAR_PROVIDER=openai-compatible

# MCP transport
MCP_TRANSPORT=stdio

# HTTP transport for private server deployment
# MCP_TRANSPORT=http
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=3000
# MCP_HTTP_PATH=/mcp
# MCP_AUTH_TOKEN=replace_with_a_long_random_token
# MCP_AUTH_HEADER=authorization
# MCP_AUTH_SCHEME=Bearer

# OpenAI-compatible endpoint. Use the /v1 base URL; the server appends /chat/completions.
OCULAR_BASE_URL=https://api.openai.com/v1
OCULAR_API_KEY=your_api_key
OCULAR_MODEL=gpt-4o-mini

# Optional custom headers, JSON string
OCULAR_HEADERS={}

# Default behavior
OCULAR_TEMPERATURE=0.1
OCULAR_MAX_TOKENS=4096
OCULAR_TIMEOUT_MS=60000

# Image limits
OCULAR_MAX_IMAGE_MB=10

# Cache (results keyed by image hash + tool + task + model + prompt version)
OCULAR_CACHE_ENABLED=true
OCULAR_CACHE_DIR=.ocular-cache

# Binary upload side channel (remote HTTP deployments)
# Directory where uploaded images are stored (content-addressed by sha256).
OCULAR_UPLOADS_DIR=.ocular-uploads
# Public base URL clients use to PUT images. Defaults to http://<MCP_HTTP_HOST>:<MCP_HTTP_PORT>.
# Set this when behind a reverse proxy with a different public address.
# OCULAR_UPLOAD_URL_BASE=http://your.public.host

# SiliconFlow Qwen example:
# OCULAR_BASE_URL=https://api.siliconflow.cn/v1
# OCULAR_MODEL=Qwen/Qwen3-VL-8B-Instruct
